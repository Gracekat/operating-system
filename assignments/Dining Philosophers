import threading
import time
import random
from datetime import datetime

#  Fork (Chopstick)

class Fork:
    def __init__(self, fork_id: int):
        self.fork_id = fork_id
        self.mutex   = threading.Lock()

    def pick_up(self):
        self.mutex.acquire()

    def put_down(self):
        self.mutex.release()



#  Philosopher

class Philosopher(threading.Thread):
    """
    Deadlock prevention  : Resource Hierarchy
                           Always acquire the lower-numbered fork first.
    Starvation prevention: A global semaphore (waiter) allows at most
                           (N-1) philosophers to compete for forks at once,
                           guaranteeing at least one can always make progress.
    """

    NUM_MEALS   = 3          # meals before a philosopher stops
    THINK_RANGE = (0.5, 1.5) # seconds
    EAT_RANGE   = (0.5, 1.0) # seconds

    _start_time = None       

    def __init__(self, philosopher_id: int, left_fork: Fork, right_fork: Fork,
                 waiter: threading.Semaphore):
        super().__init__(daemon=True)
        self.philosopher_id = philosopher_id

        if left_fork.fork_id < right_fork.fork_id:
            self.first_fork  = left_fork
            self.second_fork = right_fork
        else:
            self.first_fork  = right_fork
            self.second_fork = left_fork
        self.waiter = waiter

    def _ts(self) -> str:
        """Return elapsed time as [MM:SS]."""
        elapsed = time.time() - Philosopher._start_time
        mins    = int(elapsed) // 60
        secs    = int(elapsed) % 60
        return f"[{mins:02d}:{secs:02d}]"

    def _log(self, message: str):
        print(f"{self._ts()} Philosopher {self.philosopher_id} {message}",
              flush=True)

    def _think(self):
        self._log("is Thinking.")
        time.sleep(random.uniform(*self.THINK_RANGE))

    def _eat(self):
        self._log("is Eating.")
        time.sleep(random.uniform(*self.EAT_RANGE))

    def run(self):
        for _ in range(self.NUM_MEALS):
            self._think()

            # Waiter semaphore
            self.waiter.acquire()

            self.first_fork.pick_up()
            self._log(f"picked up Fork {self.first_fork.fork_id}.")

            self.second_fork.pick_up()
            self._log(f"picked up Fork {self.second_fork.fork_id}.")

            self._eat()

            self.second_fork.put_down()
            self._log(f"put down Fork {self.second_fork.fork_id}.")

            self.first_fork.put_down()
            self._log(f"put down Fork {self.first_fork.fork_id}.")

            self.waiter.release()

        self._log("is Done (retired).")


#  Main

def main():
    N = 5  # number of philosophers and forks

    # Create forks: fork i sits between philosopher i and (i+1) % N
    forks = [Fork(i) for i in range(N)]

    # Waiter semaphore
    waiter = threading.Semaphore(N - 1)

    # Create philosophers
    philosophers = [
        Philosopher(
            philosopher_id = i + 1,
            left_fork      = forks[i],
            right_fork     = forks[(i + 1) % N],
            waiter         = waiter
        )
        for i in range(N)
    ]

    print("=" * 55)
    print("   Dining Philosophers – Resource Hierarchy Solution")
    print("=" * 55)

    Philosopher._start_time = time.time()

    for p in philosophers:
        p.start()

    for p in philosophers:
        p.join()

    print("=" * 55)
    print("All philosophers have finished dining.")


if __name__ == "__main__":
    main()
